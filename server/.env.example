PORT=5000
NODE_ENV=development

# Local MongoDB (docker compose or installed locally)
DB_URL=mongodb://127.0.0.1:27017/yourtube

# Atlas example (add database name /yourtube)
# DB_URL=mongodb+srv://USER:PASS@cluster.mongodb.net/yourtube?retryWrites=true&w=majority

CLIENT_ORIGIN=http://localhost:3000,http://localhost:3001

# In development, LAN origins on port 3000 (e.g. http://192.168.x.x:3000) are allowed automatically.

# Multiple origins (production): comma-separated
# CLIENT_ORIGIN=https://your-app.vercel.app,https://your-app-git-main.vercel.app

UPLOAD_DIR=./uploads

# Local: JSON file path
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# Cloud (Render/Railway): entire JSON as one line — do not use file path
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Razorpay (test keys from dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_test_secret
# Premium plan prices in paise (9900 = ₹99)
RAZORPAY_PREMIUM_MONTHLY_AMOUNT=9900
RAZORPAY_PREMIUM_QUARTERLY_AMOUNT=24900
RAZORPAY_PREMIUM_YEARLY_AMOUNT=79900
# Legacy fallback for monthly if MONTHLY_AMOUNT is unset
RAZORPAY_PREMIUM_AMOUNT=9900

# Watch tier plans in paise (1000 = ₹10)
RAZORPAY_BRONZE_AMOUNT=1000
RAZORPAY_SILVER_AMOUNT=5000
RAZORPAY_GOLD_AMOUNT=10000

# Invoice + email OTP (Gmail example — see docs/OTP-INTEGRATION.md)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_gmail_app_password
# MAIL_FROM=YourTube <your@gmail.com>
# TEST_OTP_EMAIL=your@gmail.com

# Local region override (theme + OTP channel testing)
# DEV_REGION_STATE=Tamil Nadu
# DEV_REGION_CODE=TN
# DEV_CITY=Chennai

# SMS OTP for non–South India logins (Twilio — see docs/OTP-INTEGRATION.md)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890
# TEST_OTP_PHONE=9876543210
