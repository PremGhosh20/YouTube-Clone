PORT=5000
NODE_ENV=development

# Local MongoDB (docker compose or installed locally)
DB_URL=mongodb://127.0.0.1:27017/yourtube

# Atlas example (add database name /yourtube)
# DB_URL=mongodb+srv://USER:PASS@cluster.mongodb.net/yourtube?retryWrites=true&w=majority

CLIENT_ORIGIN=http://localhost:3000

# In development, LAN origins on port 3000 (e.g. http://192.168.x.x:3000) are allowed automatically.

# Multiple origins (production): comma-separated
# CLIENT_ORIGIN=https://your-app.vercel.app,https://your-app-git-main.vercel.app

UPLOAD_DIR=./uploads

# Local: JSON file path
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# Cloud (Render/Railway): entire JSON as one line — do not use file path
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
